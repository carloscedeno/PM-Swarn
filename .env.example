# Jira Configuration
JIRA_URL=https://your-domain.atlassian.net
JIRA_USER=your-email@example.com
JIRA_TOKEN=your-jira-api-token

# Notion Configuration
NOTION_TOKEN=your-notion-internal-integration-token
NOTION_DATABASE_ID=your-product-documentation-database-id
NOTION_REPORTS_PARENT_ID=your-parent-page-id-for-audit-reports

# Optional: JQL for Weekly Check
# DEFAULT_JQL=project = "PROJ" AND status = "STRATA DONE" AND updated >= "-7d"
